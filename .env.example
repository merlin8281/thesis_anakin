# Anakin.ai — required for the 114-source data layer
# Get yours at https://anakin.io
ANAKIN_API_KEY=YOUR_ANAKIN_KEY_HERE

# OpenRouter — required for AI source selection + Telegram bot brain
# Get yours at https://openrouter.ai/keys
# Format: sk-or-v1-...
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE

# Telegram bot — only needed if you want to run the conversational bot (npm run bot)
# Get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
